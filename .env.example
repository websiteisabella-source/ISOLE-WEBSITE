NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/isabellla.co/
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567
NEXT_PUBLIC_SITE_URL=https://www.tu-dominio.com

# Instagram community sync
# Use tagged for media that appears under:
# https://www.instagram.com/isabellla.co/tagged/
INSTAGRAM_SOURCE=tagged
INSTAGRAM_TAGGED_LABEL=isabellla.co
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_POST_LIMIT=6

# Optional: make npm run sync:instagram fail if credentials are missing.
INSTAGRAM_SYNC_REQUIRED=true

# Optional alternative source:
# INSTAGRAM_SOURCE=hashtags
# INSTAGRAM_HASHTAGS=isolemomentos,isolestudio

# Backend API
APP_NAME=ISOLE API
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000

# MongoDB
# Local development:
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=isole_showroom

# MongoDB Atlas example:
# Replace <password> and <cluster-host> with the credentials from Atlas.
# MONGODB_URI=mongodb+srv://websiteisabella_db_user:<password>@<cluster-host>/isole_showroom?retryWrites=true&w=majority
# DATABASE_NAME=isole_showroom

JWT_SECRET_KEY=replace-with-a-random-access-secret-of-at-least-32-chars
JWT_REFRESH_SECRET_KEY=replace-with-a-different-random-refresh-secret-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Cloudinary
# You can use either CLOUDINARY_URL or the three separate fields below.
# CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@sguhbpc0
CLOUDINARY_CLOUD_NAME=sguhbpc0
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
MAX_UPLOAD_SIZE_MB=10

# Disabled by default. For local bootstrap only, set true before registering
# the first account, then set it back to false. Production rejects true.
INITIAL_ADMIN_BOOTSTRAP_ENABLED=false
